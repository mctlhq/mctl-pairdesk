# mctl-pairdesk — environment template. Copy to `.env` for local dev; never commit a real .env.
# In production these are injected via Vault + the base-service ExternalSecret.

# --- Runtime (local dev / production) ---
DATABASE_URL=postgres://pairdesk:pairdesk@localhost:5433/pairdesk_test
DATABASE_SSL=false                 # CNPG requires SSL in-cluster; false for local
TELEGRAM_BOT_TOKEN=                 # BotFather token (initData verify + notifications). NEVER commit a real one.
SUPER_ADMIN_TELEGRAM_IDS=1000       # comma-separated super-admin Telegram ids (auto-approved, admin role)
COMMUNITY_SLUG=default
COMMUNITY_NAME=PairDesk
ORDER_TTL_SECONDS=259200            # default order TTL (72h)
INITDATA_MAX_AGE_SECONDS=86400      # initData freshness window (24h)
PORT=8099
APP_ENV=development                 # AUTH_DEV_BYPASS is hard-off when this is `production`
AUTH_DEV_BYPASS=false               # dev only: honour X-Debug-User-Id header (skips initData)

# --- E2E / integration test harness (see tests/, playwright.config.ts) ---
# A THROWAWAY shared secret used both to sign fixture initData and to boot the test
# server. It is NOT a real Telegram token and need not be valid with Telegram — it only
# has to match between signer and server so the genuine HMAC verification path is exercised.
PAIRDESK_TEST_BOT_TOKEN=test:HARNESS
PAIRDESK_TEST_PORT=8099
PAIRDESK_TEST_PG_PORT=5433
